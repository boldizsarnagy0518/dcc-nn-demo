# Copy this file to .env and fill in the provider route you want to use.
# Recommended evidence mode uses OpenRouter aliases below: one key, three model families.

OPENROUTER_API_KEY=
OPENROUTER_OPENAI_MODEL=openai/gpt-5.2
OPENROUTER_GEMINI_MODEL=google/gemini-3-pro-preview
OPENROUTER_CLAUDE_MODEL=anthropic/claude-sonnet-4.6

# Optional single OpenRouter model route for ad hoc tests.
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optional direct provider routes. Not needed for the default controlled A/B run.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
