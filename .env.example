# Copy this file to .env and fill in the providers you want to use.
# The dashboard works without these keys in local mock mode.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenRouter uses one API key for all OpenRouter models.
# Free model example for testing:
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
